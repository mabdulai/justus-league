---
import BaseHead from '@components/BaseHead.astro';
import Header from '@components/Header.astro';

interface Props {
    title: string;
    description: string;
    /** Wider main column for location cards etc. */
    contentWidth?: 'default' | 'wide';
}

const { title, description, contentWidth = 'default' } = Astro.props;
const isWide = contentWidth === 'wide';
---

<html lang="en" class:list={['page-npc', isWide && 'page-npc--wide']}>
    <head>
        <BaseHead title={title} description={description} />
        <style>
            .page-npc body {
                max-width: min(1080px, 94vw);
            }

            .page-npc.page-npc--wide body {
                max-width: min(1320px, 96vw);
            }

            .title {
                font-family: PirataOne-Regular, serif;
                font-size: clamp(2rem, 5vw, 2.75rem);
                margin: 0.15em 0 0;
                letter-spacing: 0.02em;
            }

            hr {
                border: none;
                height: 1px;
                margin: 1.25rem 0 1.75rem;
                background: linear-gradient(
                    90deg,
                    transparent,
                    rgb(183 224 126 / 35%) 20%,
                    rgb(183 224 126 / 35%) 80%,
                    transparent
                );
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <h1 class="title">{title}</h1>
                <hr />
                <slot />
            </article>
        </main>
    </body>
</html>
